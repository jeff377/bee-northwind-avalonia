<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Bee.Northwind.UI.ViewModels"
             mc:Ignorable="d"
             x:Class="Bee.Northwind.UI.Views.LoginView"
             x:DataType="vm:LoginViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.status">
      <Setter Property="Foreground" Value="{DynamicResource SemiColorText2}" />
    </Style>
    <Style Selector="TextBlock.status.error">
      <Setter Property="Foreground" Value="{DynamicResource SemiColorDanger}" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <Border Width="380" Margin="24"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Background="{DynamicResource SemiColorBackground0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="1" CornerRadius="8" Padding="28">
      <StackPanel Spacing="14">

        <TextBlock Text="Sign in" FontSize="22" FontWeight="Bold" />
        <TextBlock Text="Use demo / demo to sign in."
                   Foreground="{DynamicResource SemiColorText2}" />

        <StackPanel Spacing="6">
          <TextBlock Text="User ID" Foreground="{DynamicResource SemiColorText1}" />
          <TextBox Text="{Binding UserId, Mode=TwoWay}"
                   PlaceholderText="User ID"
                   IsEnabled="{Binding IsNotBusy}" />
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="Password" Foreground="{DynamicResource SemiColorText1}" />
          <TextBox Text="{Binding Password, Mode=TwoWay}"
                   PlaceholderText="Password"
                   PasswordChar="●"
                   IsEnabled="{Binding IsNotBusy}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12">
          <Button Content="Sign in"
                  Classes="Primary"
                  Command="{Binding LoginCommand}"
                  IsEnabled="{Binding IsNotBusy}" />
          <ProgressBar IsIndeterminate="True"
                       Width="120"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsBusy}" />
        </StackPanel>

        <TextBlock Classes="status"
                   Classes.error="{Binding IsError}"
                   Text="{Binding Status}"
                   TextWrapping="Wrap" />

      </StackPanel>
    </Border>
  </ScrollViewer>

</UserControl>
