<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Bee.Northwind.UI.ViewModels"
             xmlns:models="clr-namespace:Bee.Northwind.UI.Models"
             mc:Ignorable="d"
             x:Class="Bee.Northwind.UI.Views.FormsView"
             x:DataType="vm:FormsViewModel">

  <UserControl.Styles>
    <!-- Tab close button: flat by default, a subtle fill block only on hover / press. -->
    <Style Selector="Button.tabclose">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.tabclose:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SemiColorFill1}" />
    </Style>
    <Style Selector="Button.tabclose:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SemiColorFill2}" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- Top bar: hamburger toggles the navigation pane; brand sits next to it; the
         right-aligned switch flips the app-wide Light / Dark theme variant. -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource SemiColorBackground1}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,0,1"
            Padding="8,6">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
        <Button Grid.Column="0"
                Command="{Binding TogglePaneCommand}"
                Classes="Tertiary"
                Padding="8,4"
                ToolTip.Tip="Toggle menu"
                Content="☰" />
        <TextBlock Grid.Column="1" Text="Bee.Northwind" FontSize="16" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="10,0,0,0" />
        <ToggleSwitch Grid.Column="3"
                      x:Name="ThemeToggle"
                      OnContent="Dark" OffContent="Light"
                      IsChecked="True"
                      VerticalAlignment="Center"
                      IsCheckedChanged="OnThemeToggled" />
      </Grid>
    </Border>

    <!-- Collapsible navigation menu + content host. Inline display mode slides the whole
         pane away when collapsed so the form area takes the full width. -->
    <SplitView IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="Inline"
               OpenPaneLength="220"
               PaneBackground="{DynamicResource SemiColorBackground0}">

      <SplitView.Pane>
        <ListBox x:Name="NavList"
                 ItemsSource="{Binding NavItems}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="6,8"
                 Tapped="OnNavTapped">
          <ListBox.Styles>
            <!-- Header rows are labels, not choices: disable so selection skips them. -->
            <Style Selector="ListBoxItem">
              <Setter Property="IsEnabled" Value="{Binding !IsHeader, x:DataType=models:NavItem}" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:NavItem">
              <Panel>
                <TextBlock Text="{Binding Title}"
                           IsVisible="{Binding IsHeader}"
                           Classes="muted"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="2,8,0,2"
                           Foreground="{DynamicResource SemiColorText2}" />
                <TextBlock Text="{Binding Title}"
                           IsVisible="{Binding !IsHeader}"
                           VerticalAlignment="Center" />
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </SplitView.Pane>

      <!-- Open forms as IDE-style document tabs. Selecting a menu entry opens a new tab
           (a fresh FormView so it runs its attach-time initialisation) or switches to the
           existing one; tabs are built and de-duplicated in code-behind. -->
      <TabControl x:Name="Tabs" Margin="8" />

    </SplitView>

  </DockPanel>

</UserControl>
