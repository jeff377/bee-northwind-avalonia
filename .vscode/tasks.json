{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-northwind-server",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Bee.Northwind.Server/Bee.Northwind.Server.csproj",
        "--configuration",
        "Debug",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build-northwind-desktop",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Bee.Northwind.Desktop/Bee.Northwind.Desktop.csproj",
        "--configuration",
        "Debug",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "wait-for-northwind-server",
      "type": "shell",
      "command": "for i in $(seq 1 100); do curl -s -o /dev/null --max-time 1 http://localhost:5100/ && exit 0; sleep 0.3; done; echo 'Timed out waiting for Bee.Northwind.Server on :5100'; exit 1",
      "windows": {
        "command": "for ($i=0; $i -lt 100; $i++) { if ((Test-NetConnection -ComputerName localhost -Port 5100 -InformationLevel Quiet -WarningAction SilentlyContinue)) { exit 0 }; Start-Sleep -Milliseconds 300 }; Write-Host 'Timed out waiting for Bee.Northwind.Server on :5100'; exit 1"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "prep-northwind-desktop",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build-northwind-desktop",
        "wait-for-northwind-server"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-northwind-browser",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Bee.Northwind.Browser/Bee.Northwind.Browser.csproj",
        "--configuration",
        "Debug",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "prep-northwind-browser",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build-northwind-browser",
        "wait-for-northwind-server"
      ],
      "problemMatcher": []
    }
  ]
}
